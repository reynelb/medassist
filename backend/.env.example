# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medassist

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI (Whisper + GPT for transcription/report)
OPENAI_API_KEY=your-openai-key

# Anthropic (Claude for report generation)
ANTHROPIC_API_KEY=your-anthropic-key

# File storage (local for dev, S3 for prod)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/audio
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Video calls (Daily.co)
DAILY_API_KEY=your-daily-key
DAILY_DOMAIN=your-domain.daily.co

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173"]
